PORT=5000
CORS_ORIGIN=http://localhost:3000

# Postgres
DATABASE_URL=postgres://spaers:spaers_dev@localhost:5432/spaers

# Redis
REDIS_URL=redis://localhost:6379

# Anthropic (Claude) — used by /api/ai/suggest-coverage
ANTHROPIC_API_KEY=sk-ant-...

# Public-facing URL used in the links sent to responders (SMS / email)
PUBLIC_APP_URL=http://localhost:3000

# Admin gate (rotate any time — both backend + frontend read from env)
ADMIN_SECRET=change-me-to-a-long-random-string
ADMIN_PATH=change-me-too

# Twilio (SMS). Either TWILIO_FROM (a single Twilio phone number, e.g. +12...)
# OR TWILIO_MESSAGING_SERVICE_SID (recommended in production — Twilio handles
# routing/compliance per country automatically).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_MESSAGING_SERVICE_SID=
# Voice calls — usually the same Twilio number as TWILIO_FROM. Set only if
# you bought a separate voice-capable number for calls.
TWILIO_VOICE_FROM=
